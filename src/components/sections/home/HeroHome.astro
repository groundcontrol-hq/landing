---
// HeroHome.astro — Ground Control platform home hero
---

<section class="
  relative min-h-[calc(100vh-3.5rem)] flex flex-col justify-center
  bg-bg-base noise border-b border-border-base
  px-6 py-24 overflow-hidden
">

  <!-- Background grid -->
  <div
    class="absolute inset-0 opacity-[0.025] pointer-events-none"
    style="background-image: linear-gradient(var(--color-border-base) 1px, transparent 1px), linear-gradient(90deg, var(--color-border-base) 1px, transparent 1px); background-size: 64px 64px;"
    aria-hidden="true"
  />

  <!-- Corner marks — aerospace detail -->
  <div class="absolute top-8 left-8 w-6 h-6 border-l border-t border-border-focus opacity-40" aria-hidden="true" />
  <div class="absolute top-8 right-8 w-6 h-6 border-r border-t border-border-focus opacity-40" aria-hidden="true" />
  <div class="absolute bottom-8 left-8 w-6 h-6 border-l border-b border-border-focus opacity-40" aria-hidden="true" />
  <div class="absolute bottom-8 right-8 w-6 h-6 border-r border-b border-border-focus opacity-40" aria-hidden="true" />

  <div class="relative max-w-7xl mx-auto w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: copy -->
      <div>

        <!-- Status pill -->
        <div class="inline-flex items-center gap-2 border border-border-base bg-bg-raised px-3 py-1.5 mb-10">
          <span class="inline-block w-1.5 h-1.5 bg-pass blink" />
          <span class="font-mono text-xs text-text-muted uppercase tracking-widest">
            Now available — Sentinel free tier
          </span>
        </div>

        <h1 class="
          font-display font-bold uppercase
          text-5xl md:text-6xl xl:text-7xl
          text-text-primary
          leading-[1.02] tracking-tight mb-8
        ">
          Your IT<br />
          operations,<br />
          <span class="text-accent">under control.</span>
        </h1>

        <p class="
          font-body text-base md:text-lg text-text-muted
          max-w-lg leading-relaxed mb-10
        ">
          Ground Control gives European tech companies
          continuous visibility into their security posture,
          IT operations, and cloud infrastructure —
          without enterprise complexity or US data residency.
        </p>

        <div class="flex flex-wrap items-center gap-3 mb-12">
          <a
            href="/sentinel"
            class="
              px-6 py-3 bg-accent text-bg-base border border-accent
              font-mono text-xs uppercase tracking-widest
              hover:bg-transparent hover:text-accent
              transition-all duration-150
            "
          >
            Start with Sentinel →
          </a>
          <a
            href="#products"
            class="
              px-6 py-3 bg-transparent text-text-muted border border-border-base
              font-mono text-xs uppercase tracking-widest
              hover:border-border-focus hover:text-text-primary
              transition-all duration-150
            "
          >
            See all products
          </a>
        </div>

        <!-- Trust micro-strip -->
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
          {[
            'EU data residency',
            'NIS2 ready',
            'Founded in Italy',
          ].map(item => (
            <div class="flex items-center gap-2">
              <span class="inline-block w-1 h-1 bg-accent" />
              <span class="font-mono text-xs text-text-dim uppercase tracking-widest">
                {item}
              </span>
            </div>
          ))}
        </div>

      </div>

      <!-- Right: monitor panel -->
      <div class="relative hidden lg:block">

        <!-- Fake terminal / monitor panel -->
        <div class="card-cut bg-border-base p-px">
        <div class="bg-bg-raised card-cut overflow-hidden">

          <!-- Panel header -->
          <div class="flex items-center justify-between px-4 py-2.5 border-b border-border-base bg-bg-overlay">
            <div class="flex items-center gap-2">
              <span class="inline-block w-1.5 h-1.5 bg-pass blink" />
              <span class="font-mono text-xs text-text-muted uppercase tracking-widest">
                Ground Control / Monitor
              </span>
            </div>
            <span class="font-mono text-xs text-text-dim">
              {new Date().toISOString().split('T')[0]}
            </span>
          </div>

          <!-- Fake check results -->
          <div class="p-4 space-y-1">
            {[
              { domain: 'fourgreen.it',       status: 'pass',     checks: '8/8', time: '2m ago'  },
              { domain: 'mail.fourgreen.it',  status: 'warning',  checks: '6/8', time: '2m ago'  },
              { domain: 'acmecorp.com',       status: 'critical', checks: '4/8', time: '6h ago'  },
              { domain: 'techstartup.io',     status: 'pass',     checks: '8/8', time: '6h ago'  },
              { domain: 'eurosystems.eu',     status: 'warning',  checks: '7/8', time: '12h ago' },
            ].map(row => (
              <div class="flex items-center gap-4 px-3 py-2.5 hover:bg-bg-subtle transition-colors duration-150">
                <span class:list={[
                  "inline-block w-1.5 h-1.5 flex-shrink-0",
                  row.status === 'pass'     && "bg-pass",
                  row.status === 'warning'  && "bg-warning",
                  row.status === 'critical' && "bg-critical blink",
                ]} />
                <span class="font-mono text-xs text-text-primary flex-1 truncate">
                  {row.domain}
                </span>
                <span class="font-mono text-xs text-text-dim">{row.checks}</span>
                <span class="font-mono text-xs text-text-dim w-14 text-right">{row.time}</span>
              </div>
            ))}
          </div>

          <!-- Panel footer -->
          <div class="px-4 py-2.5 border-t border-border-dim flex items-center justify-between">
            <span class="font-mono text-xs text-text-dim">5 domains monitored</span>
            <span class="font-mono text-xs text-text-dim">Next scan in 4h 32m</span>
          </div>

        </div>
        </div>

        <!-- Decorative offset border -->
        <div class="card-cut bg-border-dim absolute -bottom-3 -right-3 w-full h-full pointer-events-none p-px -z-10" aria-hidden="true">
          <div class="w-full h-full bg-bg-base" />
        </div>
      </div>

    </div>
  </div>
</section>
