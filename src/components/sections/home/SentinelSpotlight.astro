---
// SentinelSpotlight.astro — product feature highlight on home page
import SectionMarker from "../../ui/SectionMarker.astro";

const findings = [
  {
    check: "DMARC",
    status: "critical",
    detail: "Policy set to p=none — no enforcement",
  },
  {
    check: "SPF",
    status: "pass",
    detail: "Hard fail enforced, M365 authorized",
  },
  { check: "SSL", status: "warning", detail: "Certificate expires in 28 days" },
  {
    check: "DKIM",
    status: "pass",
    detail: "selector1 and selector2 configured",
  },
  {
    check: "M365",
    status: "warning",
    detail: "Conditional Access: no country filter",
  },
];

const securityScoreBars = [
  { status: "pass", width: 4 },
  { status: "warning", width: 4 },
  { status: "critical", width: 2 },
];

const severityClass = {
  critical: "text-critical bg-critical-bg border-critical/30",
  warning: "text-warning  bg-warning-bg  border-warning/30",
  pass: "text-pass     bg-pass-bg     border-pass/30",
};

const dotClass = {
  critical: "bg-critical",
  warning: "bg-warning",
  pass: "bg-pass",
};
---

<section class="border-b border-border-base bg-bg-base px-6 py-24">
  <div class="max-w-7xl mx-auto">
    <SectionMarker label="03 / Sentinel" />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left: mock dashboard -->
      <div class="relative order-2 lg:order-1">
        <div class="card-cut bg-border-base p-px">
          <div class="bg-bg-raised card-cut overflow-hidden">
            <!-- Panel header -->
            <div
              class="flex items-center justify-between px-5 py-3 border-b border-border-base bg-bg-overlay"
            >
              <div class="flex items-center gap-2">
                <span class="inline-block w-1.5 h-1.5 bg-critical"></span>
                <span
                  class="font-mono text-xs text-text-muted uppercase tracking-widest"
                >
                  yourcompany.com
                </span>
              </div>
              <span class="font-mono text-xs text-text-dim">
                Last scan: 2 min ago
              </span>
            </div>

            <!-- Score bar -->
            <div class="px-5 py-4 border-b border-border-dim">
              <div class="flex items-center justify-between mb-2">
                <span
                  class="font-mono text-xs text-text-dim uppercase tracking-widest"
                >
                  Security score
                </span>
                <span class="font-mono text-xs">2 / 5 passing</span>
              </div>
              <div class="flex gap-0.5">
                {
                  securityScoreBars.map((bar, i) => (
                    <div
                      class:list={[
                        "h-1 flex-1",
                        dotClass[bar.status as keyof typeof dotClass],
                      ]}
                      style={{ flex: bar.width }}
                    />
                  ))
                }
              </div>
            </div>

            <!-- Findings -->
            <div class="divide-y divide-border-dim">
              {
                findings.map((f) => (
                  <div class="flex items-center gap-4 px-5 py-3.5">
                    <span class="font-mono text-xs text-text-dim w-10 shrink-0">
                      {f.check}
                    </span>
                    <span
                      class:list={[
                        "inline-flex items-center gap-1.5 px-2 py-0.5 border",
                        "font-mono text-[10px] uppercase tracking-wider shrink-0",
                        severityClass[f.status as keyof typeof severityClass],
                      ]}
                    >
                      <span
                        class:list={[
                          "inline-block w-1 h-1",
                          f.status === "critical" && "blink",
                          dotClass[f.status as keyof typeof dotClass],
                        ]}
                      />
                      {f.status}
                    </span>
                    <span class="font-mono text-xs text-text-muted truncate">
                      {f.detail}
                    </span>
                  </div>
                ))
              }
            </div>

            <!-- Panel footer -->
            <div class="px-5 py-3 border-t border-border-dim bg-bg-overlay">
              <span class="font-mono text-xs text-text-dim">
                Next scan in 5h 47m · Alerts: email + Slack
              </span>
            </div>
          </div>
        </div>

        <!-- Offset shadow border -->
        <div
          class="card-cut bg-border-dim absolute -bottom-3 -right-3 w-full h-full pointer-events-none p-px -z-10"
          aria-hidden="true"
        >
          <div class="card-cut w-full h-full bg-bg-base"></div>
        </div>
      </div>

      <!-- Right: copy -->
      <div class="order-1 lg:order-2">
        <h2
          class="font-display font-bold uppercase text-4xl text-text-primary leading-tight mb-6"
        >
          Know your security posture<br />
          <span class="text-accent">before attackers do.</span>
        </h2>

        <p class="font-body text-base text-text-muted leading-relaxed mb-8">
          Sentinel runs the same DNS and email authentication checks that
          security experts do manually — every 6 hours, automatically, for every
          domain you add.
        </p>

        <div class="space-y-4 mb-10">
          {
            [
              {
                label: "Checks run every 6 hours",
                detail: "SPF, DKIM, DMARC, SSL, MX, M365 configuration",
              },
              {
                label: "Alert before it becomes an incident",
                detail: "Email, Slack, webhook, or Microsoft Teams",
              },
              {
                label: "NIS2 compliance report on demand",
                detail: "Export a PDF mapped to Article 21 requirements",
              },
            ].map((item) => (
              <div class="flex gap-4 items-start">
                <div class="w-1 h-1 bg-accent mt-2 shrink-0" />
                <div>
                  <p class="font-mono text-sm text-text-primary mb-0.5">
                    {item.label}
                  </p>
                  <p class="font-body text-xs text-text-muted">{item.detail}</p>
                </div>
              </div>
            ))
          }
        </div>

        <div class="flex items-center gap-4">
          <a
            href="/sentinel"
            class="px-6 py-3 bg-accent text-bg-base border border-accent
              font-mono text-xs uppercase tracking-widest
              hover:bg-transparent hover:text-accent
              transition-all duration-150"
          >
            Try Sentinel free →
          </a>
          <a
            href="/sentinel#pricing"
            class="font-mono text-xs text-text-dim hover:text-text-muted transition-colors duration-150 uppercase tracking-widest"
          >
            See pricing
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
