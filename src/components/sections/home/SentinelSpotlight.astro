---
// SentinelSpotlight.astro — product feature highlight on home page
import { SectionMarker } from "@/components/ui/SectionMarker";
import { Button } from "@/components/ui/Button";
import { SeverityBadge } from "@/components/ui/SeverityBadge";
import { StatusDot } from "@/components/ui/StatusDot";
import type { Severity } from "@/components/ui/SeverityBadge";

const findings = [
  {
    check: "DMARC",
    status: "critical",
    detail: "Policy set to p=none — no enforcement",
  },
  {
    check: "SPF",
    status: "pass",
    detail: "Hard fail enforced, M365 authorized",
  },
  { check: "SSL", status: "warning", detail: "Certificate expires in 28 days" },
  {
    check: "DKIM",
    status: "pass",
    detail: "selector1 and selector2 configured",
  },
  {
    check: "M365",
    status: "warning",
    detail: "Conditional Access: no country filter",
  },
] as const;

const scoreBars = [
  { status: "pass", flex: 4 },
  { status: "warning", flex: 4 },
  { status: "critical", flex: 2 },
] as const;

const dotClass = {
  critical: "bg-critical",
  warning: "bg-warning",
  pass: "bg-pass",
} as const;
---

<section class="border-b border-border-base bg-bg-base px-6 py-32">
  <div class="max-w-7xl mx-auto">
    <SectionMarker label="03 / Product Suite" />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left: mock dashboard -->
      <div class="relative order-2 lg:order-1">
        <div class="card-cut bg-border-base p-px">
          <div class="bg-bg-raised card-cut overflow-hidden">
            <!-- Panel header -->
            <div
              class="flex items-center justify-between px-5 py-3 border-b border-border-base bg-bg-overlay"
            >
              <div class="flex items-center gap-2">
                <StatusDot color="critical" />
                <span
                  class="font-mono text-xs text-text-muted uppercase tracking-widest"
                >
                  yourcompany.com
                </span>
              </div>
              <span class="font-mono text-xs text-text-dim"
                >Last scan: 2 min ago</span
              >
            </div>

            <!-- Score bar -->
            <div class="px-5 py-4 border-b border-border-dim">
              <div class="flex items-center justify-between mb-2">
                <span
                  class="font-mono text-xs text-text-dim uppercase tracking-widest"
                  >Security score</span
                >
                <span class="font-mono text-xs">2 / 5 passing</span>
              </div>
              <div class="flex gap-0.5">
                {
                  scoreBars.map((bar) => (
                    <div
                      class:list={["h-1 flex-1", dotClass[bar.status]]}
                      style={{ flex: bar.flex }}
                    />
                  ))
                }
              </div>
            </div>

            <!-- Findings -->
            <div class="divide-y divide-border-dim">
              {
                findings.map((f) => (
                  <div class="flex items-center gap-4 px-5 py-3.5">
                    <span class="font-mono text-xs text-text-dim w-10 shrink-0">
                      {f.check}
                    </span>
                    <SeverityBadge
                      severity={f.status as Severity}
                      className="shrink-0"
                    />
                    <span class="font-mono text-xs text-text-muted truncate">
                      {f.detail}
                    </span>
                  </div>
                ))
              }
            </div>

            <!-- Panel footer -->
            <div class="px-5 py-3 border-t border-border-dim bg-bg-overlay">
              <span class="font-mono text-xs text-text-dim">
                Next scan in 5h 47m · Alerts: email + Slack
              </span>
            </div>
          </div>
        </div>

        <!-- Offset shadow border -->
        <div
          class="card-cut bg-border-dim absolute -bottom-3 -right-3 w-full h-full pointer-events-none p-px -z-10"
          aria-hidden="true"
        >
          <div class="card-cut w-full h-full bg-bg-base"></div>
        </div>
      </div>

      <!-- Right: copy -->
      <div class="order-1 lg:order-2">
        <h2
          class="font-display font-bold uppercase text-4xl text-text-primary leading-tight mb-6"
        >
          Security is one layer.<br />
          <span class="text-accent">Ground Control covers all three.</span>
        </h2>

        <p class="font-body text-base text-text-muted leading-relaxed mb-8">
          Sentinel is the security module. It monitors your DNS, email
          authentication, and certificates — continuously, not on demand.
        </p>

        <div class="space-y-5 mb-10">
          {
            [
              "Checks run every 6 hours",
              "Alert before it becomes an incident",
              "NIS2 compliance report on demand",
            ].map((label) => (
              <div class="flex gap-4 items-center">
                <StatusDot color="accent" size="xs" />
                <p class="font-mono text-sm text-text-primary">{label}</p>
              </div>
            ))
          }
        </div>

        <div class="flex items-center gap-4 mb-8">
          <Button href="/sentinel">Try Sentinel free →</Button>
          <a
            href="#products"
            class="font-mono text-xs text-text-dim hover:text-text-muted transition-colors duration-150 uppercase tracking-widest"
          >
            See all modules →
          </a>
        </div>

        <!-- Also in Ground Control -->
        <div class="border-t border-border-dim pt-6">
          <p class="font-mono text-xs text-text-dim leading-relaxed">
            Sentinel is one module.{" "}
            <a href="#products" class="text-text-muted hover:text-accent transition-colors">Desk</a>
            {" "}handles IT service management.{" "}
            <a href="#products" class="text-text-muted hover:text-accent transition-colors">Launch</a>
            {" "}handles cloud deployment.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
