---
// ProblemStrip.astro — home page, the three core problems
import { SectionMarker } from '@/components/ui/SectionMarker';

const problems = [
  {
    number: '01',
    headline: 'Your domain is being spoofed right now. You don\'t know it.',
    body: 'A missing or weak DMARC record means anyone can send email from your domain. No login required. No access to your servers. Just a free cloud account and a list of targets.',
    stat: '10,000',
    statLabel: 'spoofed emails sent from one domain in a single attack',
  },
  {
    number: '02',
    headline: 'Your IT requests live in Slack threads. Nobody owns them.',
    body: 'When someone\'s laptop breaks or an account needs provisioning, they message the IT person directly. There\'s no ticket. No SLA. No record of what was done or when.',
    stat: '4.5h',
    statLabel: 'lost per person per week to untracked IT requests',
  },
  {
    number: '03',
    headline: 'When someone leaves, their access doesn\'t.',
    body: 'Offboarding is a checklist in Notion. Half the steps are outdated. The SaaS tools nobody remembers authorizing stay connected for months. You find out when the invoice arrives or the audit happens.',
    stat: '63%',
    statLabel: 'of companies find orphaned access during security audits',
  },
];
---

<section class="border-b border-border-base bg-bg-raised px-6 py-20">
  <div class="max-w-7xl mx-auto">

    <SectionMarker label="01 / The Problem" />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-border-base">
      {problems.map((p, i) => (
        <div class:list={[
          "p-8 flex flex-col gap-6",
          i < problems.length - 1 && "border-b md:border-b-0 md:border-r border-border-base",
        ]}>

          <!-- Number -->
          <span class="font-mono text-xs text-text-dim uppercase tracking-widest">
            {p.number}
          </span>

          <!-- Headline -->
          <h2 class="font-display font-semibold text-xl text-text-primary leading-tight">
            {p.headline}
          </h2>

          <!-- Stat -->
          <div class="border-t border-border-dim pt-6">
            <div class="font-display font-bold text-4xl text-accent mb-1">
              {p.stat}
            </div>
            <div class="font-mono text-xs text-text-dim leading-relaxed">
              {p.statLabel}
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
