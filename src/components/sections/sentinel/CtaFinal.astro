---
import DomainChecker from "@/components/ui/DomainChecker";
---

<section class="bg-bg-base noise px-6 py-24 relative overflow-hidden">
  <!-- Corner marks -->
  <div
    class="absolute top-8 left-8 w-6 h-6 border-l border-t border-border-focus opacity-30"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute top-8 right-8 w-6 h-6 border-r border-t border-border-focus opacity-30"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute bottom-8 left-8 w-6 h-6 border-l border-b border-border-focus opacity-30"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute bottom-8 right-8 w-6 h-6 border-r border-b border-border-focus opacity-30"
    aria-hidden="true"
  >
  </div>

  <div class="relative max-w-3xl mx-auto text-center">
    <!-- Status -->
    <div class="flex items-center justify-center gap-2 mb-8">
      <span class="inline-block w-1.5 h-1.5 bg-pass blink"></span>
      <span class="font-mono text-xs text-text-muted uppercase tracking-widest">
        Scanning available now
      </span>
    </div>

    <h2
      class="font-display font-bold uppercase text-4xl md:text-5xl text-text-primary leading-tight mb-6"
    >
      Find out if your domain<br />
      is vulnerable.<br />
      <span class="text-accent">It takes 60 seconds.</span>
    </h2>

    <p class="font-body text-base text-text-muted mb-10 max-w-lg mx-auto">
      No credit card. No installation. No DNS changes. Enter your domain and see
      your results immediately.
    </p>

    <div class="flex justify-center">
      <DomainChecker
        hints={["Free for 3 domains", "No credit card", "EU data residency"]}
        client:visible
      />
    </div>
  </div>
</section>
