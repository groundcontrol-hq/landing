---
// DomainChecker.astro — Interactive domain scan form + results card
---

<div id="check" class="max-w-2xl">
  <div class="flex gap-0 border border-border-base">
    <input
      type="text"
      placeholder="yourcompany.com"
      id="domain-input"
      class="flex-1 bg-bg-raised px-5 py-4
        font-mono text-sm text-text-primary
        placeholder-text-dim
        border-none outline-none
        focus:bg-bg-overlay
        transition-colors duration-150"
      autocomplete="off"
      spellcheck="false"
    />
    <button
      id="check-btn"
      class="px-6 py-4
        bg-accent text-bg-base
        font-mono text-xs uppercase tracking-widest
        border-l border-accent
        hover:bg-transparent hover:text-accent
        transition-all duration-150
        shrink-0"
    >
      Scan domain →
    </button>
  </div>

  <!-- Micro-copy -->
  <div class="flex items-center gap-6 mt-3">
    {
      ["No credit card", "No installation", "Results in 60 seconds"].map(
        (item) => (
          <div class="flex items-center gap-1.5">
            <span class="inline-block w-1 h-1 bg-pass" />
            <span class="font-mono text-xs text-text-dim">{item}</span>
          </div>
        ),
      )
    }
  </div>

  <!-- Results area -->
  <div id="check-results" class="mt-6 hidden"></div>
</div>

<script>
  import { sentinelCheck } from "@/service/sentinel";

  const input = document.getElementById("domain-input") as HTMLInputElement;
  const btn = document.getElementById("check-btn") as HTMLButtonElement;
  const results = document.getElementById("check-results") as HTMLDivElement;

  function validateDomain(domain: string): boolean {
    return /^[a-zA-Z0-9][a-zA-Z0-9-]{0,61}[a-zA-Z0-9]?\.[a-zA-Z]{2,}/.test(
      domain,
    );
  }

  function skeleton(domain: string): string {
    return `
      <div class="card-cut bg-border-base p-px">
        <div class="bg-bg-raised">
          <div class="px-5 py-3 border-b border-border-base flex items-center gap-3">
            <span class="inline-block w-1.5 h-1.5 bg-accent blink flex-shrink-0"></span>
            <span class="font-mono text-xs text-accent uppercase tracking-widest">
              Scanning ${domain}…
            </span>
          </div>
          <div class="divide-y divide-border-dim">
            ${[1, 2, 3, 4]
              .map(
                () => `
              <div class="px-5 py-3 flex items-center gap-4">
                <div class="w-12 h-2.5 bg-bg-subtle animate-pulse flex-shrink-0"></div>
                <div class="w-16 h-2.5 bg-bg-subtle animate-pulse"></div>
              </div>
            `,
              )
              .join("")}
          </div>
        </div>
      </div>
    `;
  }

  function statusClasses(status: string): string {
    if (status === "critical")
      return "bg-critical-bg text-critical border-critical/30";
    if (status === "warning")
      return "bg-warning-bg text-warning border-warning/30";
    if (status === "info") return "bg-info-bg text-info border-info/30";
    return "bg-pass-bg text-pass border-pass/30";
  }

  function statusDotColor(status: string): string {
    if (status === "critical") return "bg-critical";
    if (status === "warning") return "bg-warning";
    if (status === "info") return "bg-info";
    return "bg-pass";
  }

  function overallStatus(statuses: string[]): { dot: string; label: string } {
    if (statuses.includes("critical"))
      return { dot: "bg-critical", label: "Issues found" };
    if (statuses.includes("warning"))
      return { dot: "bg-warning", label: "Warnings" };
    return { dot: "bg-pass", label: "All clear" };
  }

  function renderResults(
    domain: string,
    checkResults: Awaited<ReturnType<typeof sentinelCheck>>,
  ): string {
    const time = new Date().toLocaleTimeString("en-GB", {
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
    });
    const overall = overallStatus(checkResults.map((r) => r.status));

    return `
      <div class="card-cut bg-border-base p-px">
        <div class="bg-bg-raised">

          <!-- Card header: domain + time + CTA -->
          <div class="px-5 py-3 border-b border-border-base
            flex flex-wrap items-center gap-x-4 gap-y-2">
            <div class="flex items-center gap-2 min-w-0 flex-1">
              <span class="inline-block w-1.5 h-1.5 flex-shrink-0 ${overall.dot}"></span>
              <span class="font-mono text-xs text-text-primary uppercase tracking-widest truncate">
                ${domain}
              </span>
              <span class="font-mono text-xs text-text-dim flex-shrink-0">
                — ${overall.label}
              </span>
            </div>
            <div class="flex items-center gap-4 flex-shrink-0">
              <span class="font-mono text-xs text-text-dim tabular-nums">${time}</span>
              <a
                href="/signup?domain=${domain}"
                class="inline-flex items-center gap-1.5 px-4 py-1.5
                  bg-accent text-bg-base border border-accent
                  font-mono text-xs uppercase tracking-widest
                  hover:bg-transparent hover:text-accent
                  transition-all duration-150"
              >
                Monitor →
              </a>
            </div>
          </div>

          <!-- Check rows: status badge + name only -->
          <div class="divide-y divide-border-dim">
            ${checkResults
              .map(
                (r) => `
              <div class="px-5 py-3 flex items-center gap-4">
                <span class="inline-flex items-center gap-1.5 px-2 py-0.5
                  border font-mono text-xs uppercase tracking-wider flex-shrink-0
                  ${statusClasses(r.status)}">
                  <span class="inline-block w-1.5 h-1.5 ${statusDotColor(r.status)}"></span>
                  ${r.status}
                </span>
                <span class="font-mono text-xs text-text-muted uppercase tracking-wider">
                  ${r.title}
                </span>
              </div>
            `,
              )
              .join("")}
          </div>

        </div>
      </div>
    `;
  }

  async function runCheck() {
    const domain = input.value.trim().toLowerCase();
    if (!validateDomain(domain)) {
      input.classList.add("border-critical");
      input.style.outline = "1px solid var(--color-critical)";
      return;
    }
    input.style.outline = "";

    results.classList.remove("hidden");
    results.innerHTML = skeleton(domain);

    try {
      const checkResults = await sentinelCheck({ domain });
      results.innerHTML = renderResults(domain, checkResults);
    } catch {
      results.innerHTML = `
        <div class="border border-critical/30 bg-critical-bg px-5 py-4">
          <span class="font-mono text-xs text-critical uppercase tracking-widest">
            Check failed — verify the domain and try again.
          </span>
        </div>
      `;
    }
  }

  btn.addEventListener("click", runCheck);
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter") runCheck();
  });
</script>
