---
// SectionMarker.astro — numbered section label above headings
interface Props {
  label: string;  // e.g. "01 / THE PROBLEM"
}
const { label } = Astro.props;
---
<div class="flex items-center gap-3 mb-6">
  <div class="w-8 h-px bg-accent flex-shrink-0" />
  <span class="font-mono text-xs text-accent uppercase tracking-widest">
    {label}
  </span>
</div>
