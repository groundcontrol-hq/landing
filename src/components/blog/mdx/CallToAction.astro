---
interface Props {
  title: string;
  description?: string;
  href: string;
  label?: string;
}
const { title, description, href, label = 'Get started →' } = Astro.props;
---

<div class="my-8 border border-accent/40 bg-accent-glow p-6 card-cut relative">
  <!-- Corner accent line -->
  <div class="absolute top-0 left-0 w-8 h-px bg-accent"></div>
  <div class="absolute top-0 left-0 w-px h-8 bg-accent"></div>

  <div class="flex items-start justify-between gap-6 flex-col sm:flex-row sm:items-center">
    <div>
      <p class="font-mono text-xs text-accent uppercase tracking-widest mb-1">Action required</p>
      <p class="font-display text-base font-semibold text-text-primary">{title}</p>
      {description && (
        <p class="text-sm text-text-muted mt-1">{description}</p>
      )}
    </div>
    <a
      href={href}
      class="shrink-0 inline-flex items-center gap-2 px-5 py-2.5 font-mono text-xs uppercase tracking-widest border border-accent text-accent bg-transparent hover:bg-accent hover:text-bg-base transition-all duration-150"
    >
      {label}
    </a>
  </div>
</div>
