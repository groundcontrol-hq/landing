---
// Nav.astro — sticky navigation with mobile menu
import Logo from '../ui/Logo.astro';
import { Button } from '@/components/ui/Button';
import { StatusDot } from '@/components/ui/StatusDot';
import { PLATFORM_SIGNIN_URL, PLATFORM_SIGNUP_URL } from '@/config';

const currentPath = Astro.url.pathname;

const products = [
  { label: 'Sentinel', href: '/sentinel', live: true  },
  { label: 'Desk',     href: '/desk',     live: false },
  { label: 'Launch',   href: '/launch',   live: false },
] as const;

const nav = [
  { label: 'Blog',    href: '/blog'              },
  { label: 'Pricing', href: '/sentinel#pricing'  },
] as const;
---

<header
  id="site-nav"
  class="
    fixed top-0 inset-x-0 z-50
    border-b
    transition-all duration-300
    nav-transparent
  "
>
  <nav
    class="max-w-7xl mx-auto px-6 flex items-center justify-between h-14"
    aria-label="Main navigation"
  >

    <!-- Wordmark -->
    <a href="/" class="flex items-center gap-3 group shrink-0">
      <Logo />
      <span class="font-display text-sm font-semibold text-text-primary uppercase tracking-widest group-hover:text-accent transition-colors duration-150">
        Ground Control
      </span>
    </a>

    <!-- Products (desktop) -->
    <div class="hidden md:flex items-center gap-0 border-l border-border-base ml-8 pl-8">
      {products.map(p => (
        <a
          href={p.live ? p.href : undefined}
          class:list={[
            "flex items-center gap-2 px-4 py-1.5",
            "font-mono text-xs uppercase tracking-widest",
            "border-r border-border-dim",
            "transition-colors duration-150",
            p.live
              ? currentPath.startsWith(p.href)
                  ? "text-accent"
                  : "text-text-muted hover:text-text-primary"
              : "text-text-dim cursor-default",
          ]}
          aria-disabled={!p.live || undefined}
          tabindex={!p.live ? -1 : undefined}
          aria-current={p.live && currentPath.startsWith(p.href) ? "page" : undefined}
        >
          <StatusDot color={p.live ? 'pass' : 'muted'} size="xs" />
          {p.label}
          {!p.live && <span class="text-[10px] text-text-dim">SOON</span>}
        </a>
      ))}
    </div>

    <!-- Secondary nav (desktop) -->
    <div class="hidden md:flex items-center gap-6 ml-auto">
      {nav.map(n => (
        <a
          href={n.href}
          class:list={[
            "font-mono text-xs uppercase tracking-widest transition-colors duration-150",
            currentPath.startsWith(n.href.split('#')[0]) && n.href !== '/sentinel#pricing'
              ? "text-accent"
              : "text-text-muted hover:text-text-primary",
          ]}
          aria-current={currentPath.startsWith(n.href.split('#')[0]) && n.href !== '/sentinel#pricing' ? "page" : undefined}
        >
          {n.label}
        </a>
      ))}
    </div>

    <!-- CTA (always visible) -->
    <div class="flex items-center gap-3 ml-6">
      <a
        href={PLATFORM_SIGNIN_URL}
        class="font-mono text-xs text-text-muted uppercase tracking-widest hover:text-text-primary transition-colors duration-150 hidden md:block"
      >
        Sign in
      </a>
      <Button href={PLATFORM_SIGNUP_URL} size="sm" class="hidden sm:inline-flex">Start free →</Button>

      <!-- Hamburger toggle (mobile only) -->
      <button
        id="nav-toggle"
        type="button"
        class="md:hidden flex items-center justify-center w-9 h-9 border border-border-base text-text-muted hover:text-text-primary hover:border-border-focus transition-colors duration-150"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <!-- Hamburger icon -->
        <svg class="icon-open" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <rect x="2" y="4" width="12" height="1.25" fill="currentColor"/>
          <rect x="2" y="7.375" width="12" height="1.25" fill="currentColor"/>
          <rect x="2" y="10.75" width="12" height="1.25" fill="currentColor"/>
        </svg>
        <!-- Close icon -->
        <svg class="icon-close" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <line x1="3" y1="3" x2="13" y2="13" stroke="currentColor" stroke-width="1.25" stroke-linecap="square"/>
          <line x1="13" y1="3" x2="3" y2="13" stroke="currentColor" stroke-width="1.25" stroke-linecap="square"/>
        </svg>
      </button>
    </div>

  </nav>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="mobile-menu md:hidden border-t border-border-base bg-bg-raised overflow-hidden"
    aria-hidden="true"
  >
    <nav class="px-6 py-6" aria-label="Mobile navigation">

      <!-- Products section -->
      <p class="font-mono text-[10px] text-text-dim uppercase tracking-widest mb-3">Products</p>
      <ul class="space-y-0 mb-6" role="list">
        {products.map(p => (
          <li role="listitem">
            {p.live ? (
              <a
                href={p.href}
                class:list={[
                  "flex items-center gap-3 px-0 py-3 border-b border-border-dim",
                  "font-mono text-sm uppercase tracking-widest transition-colors duration-150",
                  currentPath.startsWith(p.href) ? "text-accent" : "text-text-muted hover:text-text-primary",
                ]}
                aria-current={currentPath.startsWith(p.href) ? "page" : undefined}
              >
                <StatusDot color="pass" size="xs" />
                {p.label}
              </a>
            ) : (
              <span class="flex items-center gap-3 px-0 py-3 border-b border-border-dim font-mono text-sm uppercase tracking-widest text-text-dim">
                <StatusDot color="muted" size="xs" />
                {p.label}
                <span class="text-[10px] ml-auto">SOON</span>
              </span>
            )}
          </li>
        ))}
      </ul>

      <!-- Secondary links -->
      <ul class="space-y-0 mb-8" role="list">
        {nav.map(n => (
          <li role="listitem">
            <a
              href={n.href}
              class:list={[
                "block py-3 border-b border-border-dim",
                "font-mono text-sm uppercase tracking-widest transition-colors duration-150",
                currentPath.startsWith(n.href.split('#')[0]) && n.href !== '/sentinel#pricing'
                  ? "text-accent"
                  : "text-text-muted hover:text-text-primary",
              ]}
            >
              {n.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA buttons -->
      <div class="flex flex-col gap-3">
        <Button href={PLATFORM_SIGNUP_URL} size="sm" class="w-full justify-center">Start free →</Button>
        <a
          href={PLATFORM_SIGNIN_URL}
          class="block text-center font-mono text-xs text-text-muted uppercase tracking-widest hover:text-text-primary transition-colors duration-150 py-2"
        >
          Sign in
        </a>
      </div>

    </nav>
  </div>

</header>

<style>
  #site-nav {
    --nav-bg: transparent;
    background-color: var(--nav-bg);
  }

  #site-nav.nav-transparent {
    --nav-bg: transparent;
    border-color: transparent;
  }

  #site-nav.nav-scrolled {
    --nav-bg: rgba(8, 11, 15, 0.65);
    border-color: var(--color-border-base);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
  }

  #site-nav.nav-scrolled::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.4'/%3E%3C/svg%3E");
    opacity: 0.035;
    pointer-events: none;
    z-index: -1;
  }

  /* Mobile menu slide animation */
  .mobile-menu {
    max-height: 0;
    transition: max-height 300ms ease;
  }

  #site-nav.menu-open .mobile-menu {
    max-height: 80vh;
    overflow-y: auto;
  }

  /* Hamburger / close icon toggle */
  #nav-toggle .icon-open  { display: block; }
  #nav-toggle .icon-close { display: none;  }

  #site-nav.menu-open #nav-toggle .icon-open  { display: none;  }
  #site-nav.menu-open #nav-toggle .icon-close { display: block; }
</style>

<script>
  const siteNav = document.getElementById('site-nav');
  const toggle  = document.getElementById('nav-toggle');
  const menu    = document.getElementById('mobile-menu');

  // Scroll transparency
  function onScroll() {
    if (window.scrollY > 20) {
      siteNav?.classList.replace('nav-transparent', 'nav-scrolled');
    } else {
      siteNav?.classList.replace('nav-scrolled', 'nav-transparent');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu toggle
  function openMenu() {
    siteNav?.classList.add('menu-open');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Close navigation menu');
    menu?.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    siteNav?.classList.remove('menu-open');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open navigation menu');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    const isOpen = siteNav?.classList.contains('menu-open');
    isOpen ? closeMenu() : openMenu();
  });

  // Close menu on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && siteNav?.classList.contains('menu-open')) {
      closeMenu();
      toggle?.focus();
    }
  });

  // Close menu when a link inside it is clicked
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close menu on resize to desktop
  const mq = window.matchMedia('(min-width: 768px)');
  mq.addEventListener('change', (e) => {
    if (e.matches) closeMenu();
  });
</script>
