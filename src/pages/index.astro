---
import Layout            from '../components/layout/Layout.astro';
import HeroHome          from '../components/sections/home/HeroHome.astro';
import ProblemStrip      from '../components/sections/home/ProblemStrip.astro';
import ProductSuite      from '../components/sections/home/ProductSuite.astro';
import EuropeTrustBar    from '../components/sections/home/EuropeTrustBar.astro';
import SentinelSpotlight from '../components/sections/home/SentinelSpotlight.astro';
import PricingTeaser     from '../components/sections/home/PricingTeaser.astro';
---

<Layout
  title="Security and IT operations for European tech companies"
  description="Ground Control gives European tech companies continuous visibility into their security posture, IT operations, and cloud infrastructure — without enterprise complexity or US data residency."
  canonical="https://groundcontrol.land"
>
  <HeroHome />
  <div data-reveal><ProblemStrip /></div>
  <div data-reveal><ProductSuite /></div>
  <div data-reveal><EuropeTrustBar /></div>
  <div data-reveal><SentinelSpotlight /></div>
  <div data-reveal><PricingTeaser /></div>
</Layout>
